generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  PLANNED
  IN_PROGRESS
  DONE
  BLOCKED
}

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  passwordHash String
  role         String   @default("viewer")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  ownedTasks   Task[]   @relation("TaskOwner")

  @@index([role])
  @@index([isActive])
}

model Task {
  id          String           @id @default(cuid())
  topic       String
  phaseRule   String?
  ownerUserId String?
  workLink    String?
  status      TaskStatus       @default(PLANNED)
  notes       String?
  startDate   DateTime?
  dueDate     DateTime?
  publishDate DateTime?
  taskTypeId  Int
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  taskType    TaskType         @relation(fields: [taskTypeId], references: [id], onDelete: Restrict)
  ownerUser   User?            @relation("TaskOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  importLinks ImportBatchTask[]

  @@index([publishDate])
  @@index([dueDate])
  @@index([startDate])
  @@index([status])
  @@index([taskTypeId])
  @@index([ownerUserId])
}

model TaskType {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tasks     Task[]
}

model ImportBatch {
  id           String           @id @default(cuid())
  fileName     String
  importedBy   String?
  dryRun       Boolean          @default(false)
  createdCount Int              @default(0)
  updatedCount Int              @default(0)
  skippedCount Int              @default(0)
  errorCount   Int              @default(0)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  rowErrors    ImportRowError[]
  taskLinks    ImportBatchTask[]
}

model ImportRowError {
  id            String      @id @default(cuid())
  importBatchId String
  rowNumber     Int
  taskCode      String?
  message       String
  createdAt     DateTime    @default(now())
  importBatch   ImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)

  @@index([importBatchId])
}

model ImportBatchTask {
  importBatchId String
  taskId        String
  action        String
  createdAt     DateTime    @default(now())
  importBatch   ImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
  task          Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@id([importBatchId, taskId])
  @@index([taskId])
}
